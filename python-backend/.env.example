# AI 小说创作助手 - 环境变量示例
#
# 使用方式：
# 1. 复制为项目根目录 .env，供 Docker Compose 使用。
# 2. 复制为 python-backend/.env，供本地 FastAPI 和 ARQ Worker 使用。
# 3. 两份文件中的数据库密码、Redis 密码和模型配置应保持一致。

# ==================== 本地 FastAPI / Worker ====================

SERVER_HOST=0.0.0.0
SERVER_PORT=8567

DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_passage_creator
DB_USER=root
DB_PASSWORD=replace-with-database-password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=replace-with-redis-password

# ==================== 安全配置 ====================

SESSION_SECRET_KEY=replace-with-a-long-random-string
SESSION_MAX_AGE=2592000
PASSWORD_SALT=replace-with-a-random-salt

# ==================== 小说大模型 ====================

LLM_PROVIDER=dashscope
LLM_TIMEOUT_SECONDS=120

DASHSCOPE_API_KEY=replace-with-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 小说后台任务 ====================

NOVEL_QUEUE_ENABLED=true
NOVEL_QUEUE_NAME=ai_novel_tasks

# ==================== Docker Compose ====================

TZ=Asia/Shanghai
MYSQL_ROOT_PASSWORD=replace-with-database-password
MYSQL_DATABASE=ai_passage_creator
MYSQL_PORT=3306

BACKEND_PORT=8123
FRONTEND_PORT=80
